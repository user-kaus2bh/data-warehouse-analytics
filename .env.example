# Database Configuration
DB_TYPE=sqlite          # sqlite or postgresql
DB_PATH=data/warehouse.db   # for SQLite

# PostgreSQL (optional - only if DB_TYPE=postgresql)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=yourpassword
PG_DATABASE=datawarehouse

# ETL Settings
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
LOG_DIR=logs
LOG_LEVEL=INFO

# Data Generation
NUM_CUSTOMERS=500
NUM_PRODUCTS=50
NUM_ORDERS=5000
NUM_CAMPAIGNS=20
START_DATE=2022-01-01
END_DATE=2024-12-31
